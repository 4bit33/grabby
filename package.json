{
  "name": "grabby",
  "version": "1.2.0",
  "description": "Modern GUI for yt-dlp with support for 1000+ services",
  "author": "4bit33",
  "license": "MIT",
  "main": "electron/main.js",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/4bit33/grabby.git"
  },
  "keywords": [
    "yt-dlp",
    "youtube-dl",
    "video-downloader",
    "electron",
    "react",
    "youtube",
    "downloader",
    "gui"
  ],
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "dist-win": "npm run build && electron-builder --win",
    "dist-mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.grabby.app",
    "productName": "grabby",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      }
    ],
    "asarUnpack": [
      "bin/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "electronLanguages": ["en", "uk"]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
